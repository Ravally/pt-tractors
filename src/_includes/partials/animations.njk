<style>
  /* ── HERO SLIDE-IN ─────────────────────────────────────────────── */
  .hero-animate > * {
    opacity: 0;
    transform: translateY(24px);
    animation: heroIn 0.7s ease forwards;
  }
  .hero-animate > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-animate > *:nth-child(2) { animation-delay: 0.25s; }
  .hero-animate > *:nth-child(3) { animation-delay: 0.4s; }
  .hero-animate > *:nth-child(4) { animation-delay: 0.55s; }
  .hero-animate > *:nth-child(5) { animation-delay: 0.7s; }

  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── FADE-IN ON SCROLL ─────────────────────────────────────────── */
  .fade-in {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* stagger children inside a fade-in parent */
  .fade-in-children > * {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .fade-in-children.visible > *:nth-child(1) { opacity:1; transform:translateY(0); transition-delay: 0s; }
  .fade-in-children.visible > *:nth-child(2) { opacity:1; transform:translateY(0); transition-delay: 0.1s; }
  .fade-in-children.visible > *:nth-child(3) { opacity:1; transform:translateY(0); transition-delay: 0.2s; }
  .fade-in-children.visible > *:nth-child(4) { opacity:1; transform:translateY(0); transition-delay: 0.3s; }
  .fade-in-children.visible > *:nth-child(5) { opacity:1; transform:translateY(0); transition-delay: 0.4s; }
  .fade-in-children.visible > *:nth-child(6) { opacity:1; transform:translateY(0); transition-delay: 0.5s; }

  /* ── SERVICE CARD HOVER ────────────────────────────────────────── */
  .service-card-hover {
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    cursor: default;
  }
  .service-card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.12);
  }
  .service-card-hover:hover .card-arrow {
    transform: translateX(5px);
  }
  .card-arrow {
    display: inline-block;
    transition: transform 0.22s ease;
  }

  /* ═══════════════════════════════════════════════════════════════
     MOBILE RESPONSIVE — max-width: 767px
     All site layouts use inline styles (no Tailwind classes), so
     we target structural containers via IDs and data attributes,
     plus override via class selectors added for mobile.
  ═══════════════════════════════════════════════════════════════ */

  @media (max-width: 767px) {

    /* ── GLOBAL ── */
    * { box-sizing: border-box; }

    /* Prevent horizontal scroll at all costs */
    body { overflow-x: hidden; }

    /* ── HOME HERO ── */
    /* Hero section: reduce min-height and padding on mobile */
    .hero-animate {
      padding: 48px 0 !important;
      max-width: 100% !important;
    }

    /* ── HOME TRUST BAR ──
       4-col grid → 2-col on mobile */
    .trust-bar-grid {
      grid-template-columns: 1fr 1fr !important;
    }
    .trust-bar-grid > div {
      border-right: none !important;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    /* ── HOME SERVICES GRID ──
       3-col → 1-col on mobile */
    .services-grid {
      grid-template-columns: 1fr !important;
    }

    /* ── HOME WHY P&T — 2-col split ──
       Stack image above text on mobile */
    .why-grid {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .why-grid .why-image {
      height: 260px !important;
      order: -1;
    }
    /* Floating stat badge: reposition so it doesn't overflow */
    .why-badge {
      bottom: -12px !important;
      right: 0 !important;
    }

    /* ── INNER PAGE — 2-col content + image sections ── */
    .two-col-split {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    /* Fixed-height images in 2-col layouts → responsive height */
    .two-col-split .split-image {
      height: 260px !important;
    }

    /* ── SERVICES PAGE — Transport & Hire 2-col ── */
    .two-col-cards {
      grid-template-columns: 1fr !important;
    }

    /* ── PARTS PAGE — What We Stock + Fieldmaster 2-col ── */
    .parts-grid {
      grid-template-columns: 1fr !important;
    }

    /* ── SALES PAGE — Second-hand + Fieldmaster 2-col ── */
    .sales-grid {
      grid-template-columns: 1fr !important;
    }
    /* Fieldmaster product list inside dark card: 2-col → 1-col */
    .fieldmaster-list {
      grid-template-columns: 1fr !important;
    }

    /* ── ABOUT PAGE — Story grid 2-col → 1-col ── */
    .about-story-grid {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .about-story-grid .story-image {
      height: 260px !important;
    }
    /* Team cards: 2-col stays OK at 375px since max-width:640px constrains them,
       but force 1-col for very narrow screens */
    .team-cards {
      grid-template-columns: 1fr !important;
      max-width: 320px !important;
    }
    /* Credentials: 3-col → 1-col */
    .credentials-grid {
      grid-template-columns: 1fr !important;
    }

    /* ── CONTACT PAGE — 2-col layout → stack ── */
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
    /* Direct contacts inside contact: 2-col → 1-col */
    .direct-contacts {
      grid-template-columns: 1fr !important;
    }
    /* Form: phone + email row → 1-col */
    .form-two-col {
      grid-template-columns: 1fr !important;
    }

    /* ── FOOTER — 4-col → 1-col ── */
    .footer-grid {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .footer-bottom {
      flex-direction: column !important;
      gap: 8px !important;
      text-align: center !important;
    }

    /* ── CTA BANNER ── */
    .cta-banner-inner {
      flex-direction: column !important;
      align-items: flex-start !important;
      padding-top: 40px !important;
      padding-bottom: 40px !important;
    }

    /* ── BUTTON TAP TARGETS ── ensure min 44px height ── */
    a[href^="tel"],
    a[href^="/contact"],
    button[type="submit"] {
      min-height: 44px;
    }
  }

  /* ── MEDIUM BREAKPOINT (768px - 1023px) ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    /* Trust bar: 2-col on tablet */
    .trust-bar-grid {
      grid-template-columns: 1fr 1fr !important;
    }
    .trust-bar-grid > div {
      border-right: none !important;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .trust-bar-grid > div:nth-child(odd) {
      border-right: 1px solid rgba(255,255,255,0.08) !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.fade-in, .fade-in-children').forEach(el => {
      observer.observe(el);
    });
  });
</script>
